{
  "applicationId": "js.kaplay.kaplayground",
  "version": "3.0.0",
  "defaultMode": "window",
  "documentRoot": "/dist/",
  "url": "/dist/",
  "enableServer": true,
  "enableNativeAPI": true,
  "nativeAllowList": [
    "app.*",
    "filesystem.*"
  ],
  "modes": {
    "window": {
      "title": "myapp",
      "width": 800,
      "height": 500,
      "minWidth": 400,
      "minHeight": 200,
      "icon": "/www/icon.png"
    }
  },
  "cli": {
    "binaryName": "myapp",
    "resourcesPath": "/dist/",
    "extensionsPath": "/extensions/",
    "binaryVersion": "6.0.0",
    "clientVersion": "6.0.0",
    "frontendLibrary": {
      "patchFile": "/index.html",
      "devUrl": "http://localhost:5173",
      "projectPath": "/src/",
      "initCommand": "pnpm install",
      "devCommand": "BROWSER=none npm run dev",
      "buildCommand": "npm run build"
    }
  }
}
